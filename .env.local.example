# =============================================
# Craig du Toit Nel — Environment Variables
# =============================================
# Copy this file to .env.local and fill in your values.

# Supabase (add when setting up the database)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# NVIDIA Nemotron (free AI chatbot)
# Get your key at: https://integrate.api.nvidia.com
NVIDIA_API_KEY=nvapi-your_key_here

# ElevenLabs (voice bot — scaffold only for now)
# TODO: Add ElevenLabs API key for voice features
ELEVENLABS_API_KEY=your_elevenlabs_api_key
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=your_agent_id

# Paystack (South Africa payments)
# TODO: Add live keys when ready to accept payments
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key

# App
NEXT_PUBLIC_SITE_URL=https://craigdutoitnel.co.za
